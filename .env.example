# Copy this file to .env and fill in real values (.env is gitignored).
#   cp .env.example .env

# --- Database -----------------------------------------------------------
# Password for the PostgreSQL user. Must match what the docker-compose
# Postgres container was initialized with (defaults to "postgres" on both
# sides, so you can leave this unset for local development).
# POSTGRES_PASSWORD=postgres

# --- OAuth sign-in ------------------------------------------------------
# GitHub: https://github.com/settings/developers -> New OAuth App
#   Authorization callback URL: http://localhost:3000/users/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google: https://console.cloud.google.com/apis/credentials -> OAuth client ID (Web application)
#   Authorized redirect URI: http://localhost:3000/users/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Mail ---------------------------------------------------------------
# From-address for Devise emails (password reset, etc.).
# DEVISE_MAILER_SENDER=no-reply@example.com
